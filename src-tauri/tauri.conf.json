{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Matthew",
  "version": "0.1.0",
  "identifier": "io.github.story-essentia.matthew",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src https://openrouter.ai https://api.github.com https://github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBNjkyMTBBQzg0RDcyQzUKUldURmNrM0lDaUZwK2o0Nk1CUnExNWJ1MGlJdG5JekdwZTJvK2pUYVhiSnNCL3BEUlhuS0E0KzEK",
      "endpoints": [
        "https://github.com/story-essentia/matthew/releases/latest/download/latest.json"
      ]
    }
  }
}
